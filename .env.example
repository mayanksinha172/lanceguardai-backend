# PostgreSQL connection string from Neon (neon.tech) or Supabase
# Neon: Settings → Connection Details → Connection string
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

GMAIL_ADDRESS=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-landing-page.vercel.app,https://your-admin-dashboard.vercel.app
